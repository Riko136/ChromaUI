{
  "name": "chromaui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently --raw -n frontend,backend -c blue,green \"npm run dev -w @chromaui/frontend\" \"npm run dev -w @chromaui/backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start -w @chromaui/backend",
    "test": "jest --verbose"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "concurrently@9.2.1": true,
    "esbuild@0.28.1": true,
    "msw@2.13.6": true,
    "onnxruntime-node@1.21.0": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
